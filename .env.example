# DeepSeek OpenAI-compatible endpoint. Replace only the key in local .env.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=4096
LLM_THINKING_ENABLED=true
LLM_REASONING_EFFORT=high

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

RAG_INDEX_DIR=data/rag
RAG_TOP_K=6
QA_GRAPH_LIMIT=50
QA_ENABLE_LLM_CYPHER=true
KG_DATA_DIR=data/curated
QA_GRAPH_BACKEND=auto
QA_CORE_COMPANIES_ONLY=true
QA_RERANK_TOP_N=40
QA_EVIDENCE_TOP_N=10
QA_HISTORY_MAX_TURNS=8
QA_HISTORY_MAX_CHARS=16000
