# DeepSeek OpenAI-compatible endpoint. Replace only the key in local .env.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_THINKING_ENABLED=false
LLM_REASONING_EFFORT=low

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

RAG_INDEX_DIR=data/rag
RAG_TOP_K=6
RAG_SEARCH_CACHE_SIZE=128
QA_GRAPH_LIMIT=50
QA_ENABLE_LLM_CYPHER=false
QA_ENABLE_LLM_PLANNER=false
QA_CONTEXTUALIZER_MODE=auto
KG_DATA_DIR=data/curated
QA_GRAPH_BACKEND=auto
QA_CORE_COMPANIES_ONLY=true
QA_RERANK_TOP_N=12
QA_EVIDENCE_TOP_N=6
QA_HISTORY_MAX_TURNS=3
QA_HISTORY_MAX_CHARS=4000
QA_UI_RENDER_LATEST_ONLY=true
